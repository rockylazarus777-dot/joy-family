# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.joyfmsclinic.com

# ── Google Analytics 4 ────────────────────────────────────────
# Measurement ID from GA4 property → Admin → Data Streams → Web stream
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Tag Manager ────────────────────────────────────────
# Container ID from GTM → Admin → Container Settings
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── SMTP (Nodemailer) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@joyfmsclinic.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM_EMAIL="Joy Family Clinic <no-reply@joyfmsclinic.com>"
NOTIFICATION_TO_EMAIL=info@joyfmsclinic.com
